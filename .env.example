# NapCat Platform Environment Variables
# Copy this file to .env.local and fill in your values

# MiMo TTS API Key (required for voice reply)
MIMO_API_KEY=your-mimo-api-key-here

# NapCat WS connection
NAPCAT_WS_URL=ws://115.190.250.31:3001
NAPCAT_WS_TOKEN=your-ws-token

# NapCat HTTP API
NAPCAT_API_URL=http://115.190.250.31:3000
NAPCAT_API_TOKEN=your-api-token

# Platform auth token (for login)
PLATFORM_TOKEN=your-platform-token
